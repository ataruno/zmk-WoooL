#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/input/input-event-codes.h>
#include <dt-bindings/zmk/input_transform.h>
#include <input/processors.dtsi>
#include <physical_layouts.dtsi>

#define ARROW 1
#define NUM 2
#define AHK 3
#define FUNCTION 4

&gpio0 {
    status = "okay";
};

/ {
    chosen {
        zmk,physical-layout = &WoooL_physical_layout;
    };

    WoooL_physical_layout: WoooL_physical_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default";
        transform = <&default_transform>;
        kscan = <&kscan0>;

        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100    0   30       0     0     0>
            , <&key_physical_attrs 100 100  100   30       0     0     0>
            , <&key_physical_attrs 100 100  200   10       0     0     0>
            , <&key_physical_attrs 100 100  300    0       0     0     0>
            , <&key_physical_attrs 100 100  400   10       0     0     0>
            , <&key_physical_attrs 100 100  500   20       0     0     0>
            , <&key_physical_attrs  50  50  900  600       0     0     0>
            , <&key_physical_attrs 100 100    0  130       0     0     0>
            , <&key_physical_attrs 100 100  100  130       0     0     0>
            , <&key_physical_attrs 100 100  200  110       0     0     0>
            , <&key_physical_attrs 100 100  300  100       0     0     0>
            , <&key_physical_attrs 100 100  400  110       0     0     0>
            ;
    };

    kscan0: kscan_0 {
        compatible = "zmk,kscan-gpio-charlieplex";
        interrupt-gpios = <&xiao_d 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
        gpios
            = <&xiao_d 0 GPIO_ACTIVE_HIGH>
            , <&xiao_d 1 GPIO_ACTIVE_HIGH>
            , <&xiao_d 2 GPIO_ACTIVE_HIGH>
            , <&xiao_d 3 GPIO_ACTIVE_HIGH>
            , <&xiao_d 4 GPIO_ACTIVE_HIGH>
            , <&xiao_d 5 GPIO_ACTIVE_HIGH>
            , <&xiao_d 8 GPIO_ACTIVE_HIGH>
            , <&xiao_d 9 GPIO_ACTIVE_HIGH>
            , <&xiao_d 10 GPIO_ACTIVE_HIGH>
            ;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        rows = <4>;
        columns = <5>;
        map = <
            RC(0,1) RC(1,0) RC(2,0) RC(3,0) RC(4,0) RC(5,0) RC(0,5) RC(1,5) RC(2,5) RC(3,5) RC(4,5) RC(5,4) 
            RC(0,2) RC(1,2) RC(2,1) RC(3,1) RC(4,1) RC(5,1) RC(0,6) RC(1,6) RC(2,6) RC(3,6) RC(4,6) RC(5,6) 
            RC(0,3) RC(1,3) RC(2,3) RC(3,2) RC(4,2) RC(5,2) RC(0,7) RC(1,7) RC(2,7) RC(3,7) RC(4,7) RC(5,7) 
            RC(0,4) RC(1,4) RC(2,4) RC(3,4) RC(4,3) RC(5,3) RC(0,8) RC(1,8) RC(2,8) RC(3,8) RC(4,8) RC(5,8) 
                                    RC(6,0)                                 RC(7,0)
                            RC(6,3) RC(6,4) RC(6,2)    RC(7,5)      RC(7,3) RC(7,4) RC(7,2)
                                    RC(6,1)                                 RC(7,1)
        >;
    };

    right_encoder: encoder_right {
        compatible = "alps,ec11";
        a-gpios = <&xiao_d 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&gpio0 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <20>;
        status = "disabled";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&right_encoder>;
        triggers-per-rotation = <12>;
    };
};

&xiao_i2c { status = "disabled"; };
&xiao_serial { status = "disabled"; };